generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Property {
  id               String   @id @default(uuid())
  titleAr          String   // Arabic Title
  titleEn          String   // English Title
  type             String   // 'SALE' or 'RENT'
  propertyCategory String   @default("VILLA") // 'VILLA', 'APARTMENT', 'LAND', 'OFFICE', 'SHOP', 'BUILDING', 'ROOM'
  paymentFrequency String?  // 'YEARLY' or 'MONTHLY'
  paymentsCount    Int?     // e.g. 1, 2, 4 payments
  area             Float    @default(0)
  details          String?  // JSON stringified array of {key, value}
  locationLink     String?  // Google maps link
  locationText     String?  // Plain text location/neighborhood
  description      String
  features         String?  // Comma separated features
  propertyAge      Int      @default(0)
  electricityCost  Float    @default(0) // 0 if included/not applicable
  electricityFrequency String? // YEARLY or MONTHLY
  vat              Float    @default(0) // VAT amount
  vatExempt        Boolean  @default(false)
  utilityBills     String   @default("NONE") // 'NONE', 'ELECTRICITY', 'WATER', 'BOTH'
  commission       Float    @default(0)
  price            Float
  imageUrls        String   @default("[]") // JSON stringified array of base64 images
  attachments      String   @default("[]") // JSON stringified array of attachments: {name, url, size}
  aqarLink         String?  // Direct link to the Aqar landing page
  allowedPaymentPlans String @default("[\"1\",\"2\",\"4\"]")
  videoUrl         String?  // base64 video string or direct video URL
  status           String   @default("PUBLISHED") // 'DRAFT' or 'PUBLISHED'
  createdAt        DateTime @default(now())

  userId           String?
  user             User?    @relation(fields: [userId], references: [id])

  parentId         String?
  parent           Property?  @relation("SubProperties", fields: [parentId], references: [id], onDelete: Cascade)
  subProperties    Property[] @relation("SubProperties")
}

model Service {
  id          String   @id @default(uuid())
  nameAr      String   // e.g., تطوير، تأجير، إدارة املاك
  nameEn      String   // e.g., Development, Leasing, Property Management
  description String
}

model Admin {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String   // Plain or Hashed
  name      String   @default("Administrator")
  role      String   @default("ADMIN") // ADMIN, MANAGER, AGENT
  email     String?
  createdAt DateTime @default(now())
}

model User {
  id       String @id @default(uuid())
  username String @unique
  password String
  name     String
  properties Property[]
}

model Project {
  id               String   @id @default(uuid())
  titleAr          String   // Arabic Title
  titleEn          String   // English Title
  tier             String   @default("OTHER") // 'BIG', 'MID', 'OTHER'
  propertyCategory String   @default("VILLA") // 'VILLA', 'APARTMENT', etc.
  area             Float    @default(0)
  details          String?  // JSON stringified array of {key, value}
  locationLink     String?  // Google maps link
  locationText     String?  // Plain text location/neighborhood
  description      String
  features         String?  // Comma separated features
  propertyAge      Int      @default(0)
  imageUrls        String   @default("[]") // JSON stringified array of base64 images
  createdAt        DateTime @default(now())
}

model Settings {
  id                 String  @id @default("global")
  whatsappNumber     String  @default("966500000000")
  callingNumber      String  @default("966500000000")
  whatsappMessage    String  @default("مرحباً، أنا مهتم بهذا العقار: {title} - {link}")
  otpWebhookUrl      String?
  otpMessageTemplate String  @default("رمز التحقق الخاص بك هو: {otp}")
  otpWebhookPayload  String?
  homeImages         String? // JSON stringified object: {hero, service1, service2, service3, service4}
  logoUrl            String? // base64 or URL for the site logo
  // Social Media & Contact
  email              String?
  instagramUrl       String?
  twitterUrl         String?
  facebookUrl        String?
  linkedinUrl        String?
  youtubeUrl         String?
  tiktokUrl          String?
  snapchatUrl        String?
  notificationEmail  String?
  // Custom SMTP settings
  smtpHost           String?
  smtpPort           Int?
  smtpUser           String?
  smtpPass           String?
  smtpFrom           String?
  // Custom IMAP settings
  imapHost           String?
  imapPort           Int?
  // Custom Open-Source Analytics
  analyticsScript    String?
  analyticsDashboardUrl String?
  // Address & Map Links
  addressAr          String?
  addressEn          String?
  addressMapLink     String?
  // TechHub Integration Settings
  techhubEnabled     Boolean @default(false)
  techhubClientId    String?
  techhubClientSecret String?
  techhubApiKey      String?
  techhubSandboxMode Boolean @default(true)
  // SEO Settings
  indexNowKey        String?
}

model PageView {
  id         String   @id @default(uuid())
  path       String
  propertyId String?  // Optional, for property views
  ipAddress  String?
  createdAt  DateTime @default(now())
}

model Building {
  id              String   @id @default(uuid())
  name            String
  transferDetails String?
  photos          String?  @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  units           RenterUnit[]
}

model RenterUnit {
  id              String   @id @default(uuid())
  buildingId      String
  building        Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  unitNumber      String
  renterName      String
  renterPhone     String
  contractEndDate String?
  isTanfeeth      Boolean  @default(false)
  nextRentDue     String?
  rentAmount      Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  rentHistory     RentHistory[]
}

model RentHistory {
  id           String   @id @default(uuid())
  renterUnitId String
  renterUnit   RenterUnit @relation(fields: [renterUnitId], references: [id], onDelete: Cascade)
  dueDate      String?
  paidDate     String?
  amount       String?
  receiptUrl   String?
  createdAt    DateTime @default(now())
}

model Receipt {
  id           String   @id @default(uuid())
  renterName   String
  renterPhone  String
  buildingName String?
  unitNumber   String?
  amount       String?
  dueDate      String?
  receiptUrl   String
  createdAt    DateTime @default(now())
}

model OtpSession {
  id        String   @id @default(uuid())
  phone     String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model CallbackRequest {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String
  message   String?
  createdAt DateTime @default(now())
  status    String   @default("PENDING") // PENDING, REPLIED_WHATSAPP, STILL_GOING, CLOSED
  handledBy String?  // Name of the user who handled it
  notes     CallbackNote[]
}

model CallbackNote {
  id                String          @id @default(uuid())
  callbackRequestId String
  callbackRequest   CallbackRequest @relation(fields: [callbackRequestId], references: [id], onDelete: Cascade)
  text              String          // HTML/Plain Text reply content
  authorName        String          // Name of the user who replied
  createdAt         DateTime        @default(now())
}

model ActionLog {
  id        String   @id @default(uuid())
  userId    String
  userName  String
  userRole  String
  action    String   // ADD_PROPERTY, UPDATE_SETTINGS, etc.
  details   String
  createdAt DateTime @default(now())
}

